generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  appleId          String?   @unique @map("apple_id")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  investmentHorizon InvestmentHorizon? @default(MID_TERM) @map("investment_horizon")
  tradingMode       TradingMode        @default(STOCKS) @map("trading_mode")

  transactions  Transaction[]
  positions     Position[]
  realizedGains RealizedGain[]

  @@map("users")
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  symbol    String
  type      TransactionType
  assetType AssetType       @default(STOCK) @map("asset_type")
  quantity  Decimal         @db.Decimal(18, 8)
  price     Decimal         @db.Decimal(18, 8)
  fees      Decimal         @default(0) @db.Decimal(18, 8)
  createdAt DateTime        @default(now()) @map("created_at")
  deletedAt DateTime?       @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, symbol])
  @@index([userId, createdAt])
  @@map("transactions")
}

model Position {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  symbol        String
  assetType     AssetType @default(STOCK) @map("asset_type")
  totalQuantity Decimal   @default(0) @map("total_quantity") @db.Decimal(18, 8)
  averagePrice  Decimal   @default(0) @map("average_price") @db.Decimal(18, 8)
  totalInvested Decimal   @default(0) @map("total_invested") @db.Decimal(18, 8)
  deletedAt     DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("positions")
}

model RealizedGain {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  symbol    String
  assetType AssetType @default(STOCK) @map("asset_type")
  quantity  Decimal   @db.Decimal(18, 8)
  sellPrice Decimal   @map("sell_price") @db.Decimal(18, 8)
  avgPrice  Decimal   @map("avg_price") @db.Decimal(18, 8)
  profit    Decimal   @db.Decimal(18, 8)
  fees      Decimal   @default(0) @db.Decimal(18, 8)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("realized_gains")
}

model Stock {
  symbol    String   @id
  name      String?
  sector    String?
  marketCap String?  @map("market_cap")
  pe        Decimal? @db.Decimal(10, 4)
  updatedAt DateTime @updatedAt @map("updated_at")

  priceHistory StockPriceHistory[]

  @@map("stocks")
}

model StockPriceHistory {
  id            BigInt   @default(autoincrement())
  symbol        String
  price         Decimal  @db.Decimal(18, 8)
  changePercent Decimal? @map("change_percent") @db.Decimal(10, 4)
  timestamp     DateTime @default(now())

  stock Stock @relation(fields: [symbol], references: [symbol])

  @@id([id, timestamp])
  @@index([symbol, timestamp])
  @@map("stock_price_history")
}

enum TransactionType {
  BUY
  SELL
}

enum InvestmentHorizon {
  SPECULATION
  MID_TERM
  LONG_TERM
}

model GoldCategory {
  id        String   @id // e.g., "GOLD_24K", "GOLD_21K"
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  unit      String   // "gram", "ounce", "piece"
  purity    Decimal? @db.Decimal(5, 4) // e.g., 0.9999, 0.8750
  weightGrams Decimal? @map("weight_grams") @db.Decimal(10, 4) // fixed weight for gold pound/bar
  updatedAt DateTime @updatedAt @map("updated_at")

  priceHistory GoldPriceHistory[]

  @@map("gold_categories")
}

model GoldPriceHistory {
  id            BigInt   @default(autoincrement())
  categoryId    String   @map("category_id")
  buyPrice      Decimal  @map("buy_price") @db.Decimal(18, 4)
  sellPrice     Decimal  @map("sell_price") @db.Decimal(18, 4)
  globalSpotUsd Decimal? @map("global_spot_usd") @db.Decimal(18, 4)
  timestamp     DateTime @default(now())

  category GoldCategory @relation(fields: [categoryId], references: [id])

  @@id([id, timestamp])
  @@index([categoryId, timestamp])
  @@map("gold_price_history")
}

enum TradingMode {
  STOCKS
  GOLD
}

enum AssetType {
  STOCK
  GOLD
}
